---
import '../styles/tokens.css';
import styles from '../styles/page.module.css';
import GarmentDecoderTool from '../components/GarmentDecoderTool.astro';
const s = styles;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Garment Construction Decoder</title>
  <meta name="description" content="Describe a garment and get a structured technical breakdown: seam types, fabric behavior, interfacing, closures, and construction order." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Archivo:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <main class={s['tool-page']}>

    <div class={s['page-header']}>
      <span class={s['page-label']}>Tool</span>
      <h1 class={s['page-title']}>Garment Construction Decoder</h1>
      <p class={s['page-desc']}>Describe a garment — or upload a photo — and get a technical breakdown: seam types, fabric behavior, lining, interfacing, closure options, and a numbered construction order. Womenswear in silk, wool, cotton, and linen.</p>
    </div>

    <GarmentDecoderTool />

  </main>

</body>
</html>

<style is:global>
  body {
    background: var(--off-white);
    color: var(--black);
    font-family: var(--font-body);
    font-weight: 300;
    overflow-x: hidden;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  img { user-select: none; -webkit-user-drag: none; }
</style>
